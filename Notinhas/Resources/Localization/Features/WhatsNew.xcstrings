    "whats-new.notarization.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Notarization"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Xác thực từ Apple"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Notarisierung"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Notarización de Apple"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Notarisation d'Apple"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple公証"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 공증"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нотариальное заверение Apple"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 公证认证"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple 公證認證"
          }
        }
      }
    },
    "whats-new.notarization.desc": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Notinhas is now officially registered with the Apple Developer Program and certified by Apple, bypassing Gatekeeper's protections for a secure launch."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Notinhas hiện đã đăng ký Apple Developer Program và được Apple xác thực (Notarized), giúp ứng dụng khởi chạy an toàn và vượt qua lớp bảo vệ Gatekeeper."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Notinhas ist jetzt offiziell beim Apple Developer Program registriert und von Apple zertifiziert, um die Gatekeeper-Schutzfunktionen für einen sicheren Start zu umgehen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Notinhas ahora está oficialmente registrada en el Programa de Desarrolladores de Apple y certificada por Apple, lo que evita las protecciones de Gatekeeper para un inicio seguro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Notinhas est désormais officiellement enregistrée auprès du programme de développement Apple et certifiée by Apple, contournant les protections Gatekeeper pour un lancement sécurisé."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "NotinhasはApple Developer Programに正式に登録され、Appleによって公証（Notarized）されました。これにより、Gatekeeperの保護を回避して安全に起動できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Notinhas는 이제 공식적으로 Apple Developer Program에 등록되고 Apple의 공증(Notarized)을 받아, Gatekeeper 보안을 통과하고 안전하게 실행할 수 있습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Notinhas теперь официально зарегистрировано в программе разработчиков Apple и заверено Apple, что позволяет обходить защиту Gatekeeper для безопасного запуска."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Notinhas 现已正式注册 Apple 开发者计划并获得 Apple 公证认证，绕过 Gatekeeper 保护以实现安全启动。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "Notinhas 現已正式註冊 Apple 開發者計劃並獲得 Apple 公證認證，繞過 Gatekeeper 保護以實現安全啟動。"
          }
        }
      }
    }
  },
  "version": "1.0"
}